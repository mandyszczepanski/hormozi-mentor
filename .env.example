# === DATABASE ===
DATABASE_URL=           # [CLOUD] Neon Postgres connection string (when set, overrides SQLite)
DB_PATH=./hormozi.db   # [LOCAL] SQLite file path, used when DATABASE_URL is not set

# === AI / EMBEDDINGS ===
VOYAGE_API_KEY=pa-...           # Voyage AI embeddings API key
YOUTUBE_API_KEY=AIzaSy...       # YouTube Data API key

# === SERVER ===
PORT=3456              # HTTP server port (default 3456)
