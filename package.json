{
  "name": "hormozi-mentor",
  "version": "1.0.0",
  "description": "Alex Hormozi RAG mentor agent - YouTube-first knowledge base with MCP tool integration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "ingest": "ts-node scripts/ingest-youtube.ts",
    "cron": "ts-node scripts/cron-ingest.ts",
    "query": "ts-node -e \"const q = process.argv[2]; import('./src/query').then(m => m.query(q).then(r => console.log(r)))\" --",
    "db:init": "ts-node src/db/init.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.11.1",
    "express": "^4.18.2",
    "googleapis": "^140.0.0",
    "node-cron": "^3.0.3",
    "sqlite-vec": "^0.1.9",
    "sqlite-vec-darwin-arm64": "^0.1.9",
    "youtube-transcript": "^1.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
